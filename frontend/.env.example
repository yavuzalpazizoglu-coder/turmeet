# ── Turmeet Frontend ortam değişkenleri ─────────────────────────
# Kopyalayın: cp .env.example .env.local

# Mock veri katmanı (true = backend olmadan çalışır)
NEXT_PUBLIC_USE_MOCKS=true

# Laravel API adresi (mock kapalıyken kullanılır)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Otel logoları için logo.dev token'ı (opsiyonel — yoksa Google Favicon)
NEXT_PUBLIC_LOGODEV_TOKEN=

# ── AI Destek Asistanı (/api/ai-chat) + AI Arama (/api/ai-search) ──
# Sağlayıcı: gemini | claude
# Anahtar girilmezse: ai-chat FAQ motoruna, ai-search regex
# çözümleyicisine düşer — site anahtarsız da tam çalışır.
# Ayrıntı: docs/AI_ENTEGRASYONU.md
AI_PROVIDER=gemini

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Mesaj Çevirisi (/api/translate — staff paneli) ──────────────
# Sağlayıcı: google | deepl
# Anahtar girilmezse Google'ın anahtarsız gtx endpoint'i kullanılır
# (dev/demo için yeterli; canlıda anahtar önerilir).
TRANSLATE_PROVIDER=google

# Google Cloud Translation — https://console.cloud.google.com/apis/library/translate.googleapis.com
GOOGLE_TRANSLATE_API_KEY=

# DeepL — https://www.deepl.com/pro-api (free anahtarlar ":fx" ile biter)
DEEPL_API_KEY=
